# =============================================================================
# RMBL Knowledge Hub — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# NEVER commit .env to version control — it's in .gitignore.
# =============================================================================

# Database (local PostgreSQL for development)
DATABASE_URL=postgresql://localhost:5432/rmbl_knowledge_hub

# Payload CMS
PAYLOAD_SECRET=dev-secret-change-in-production-at-least-32-chars
PAYLOAD_ADMIN_EMAIL=ikb@rmbl.org
PAYLOAD_ADMIN_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Production Sync (required for sync:pull, sync:push, sync:full, etc.)
# ---------------------------------------------------------------------------
# NEON_DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
# NEON_DIRECT_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ---------------------------------------------------------------------------
# S3-Compatible Storage (optional — only needed for production file uploads)
# ---------------------------------------------------------------------------
# S3_BUCKET=rmbl-knowledge-hub
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1
# S3_ENDPOINT=

# ---------------------------------------------------------------------------
# External APIs (optional — defaults are built into scripts/lib/config.ts)
# ---------------------------------------------------------------------------
# CROSSREF_MAILTO=knowledgehub@rmbl.org
# UNPAYWALL_EMAIL=knowledgehub@rmbl.org
# OPENALEX_MAILTO=knowledgehub@rmbl.org

# ---------------------------------------------------------------------------
# Voyage AI (optional — only needed for embedding generation)
# Get a key at https://dash.voyageai.com/
# ---------------------------------------------------------------------------
# VOYAGE_API_KEY=

# ---------------------------------------------------------------------------
# Anthropic (optional — only needed for VLM extraction experiment)
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=
