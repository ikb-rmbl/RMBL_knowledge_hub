# Database (local PostgreSQL for development, Neon for production)
DATABASE_URL=postgresql://localhost:5432/rmbl_knowledge_hub

# Payload CMS
PAYLOAD_SECRET=dev-secret-change-in-production-at-least-32-chars

# Payload Admin (used by pipeline scripts)
PAYLOAD_ADMIN_EMAIL=admin@rmbl.org
PAYLOAD_ADMIN_PASSWORD=dev-password-change-me

# S3-Compatible Storage (configure for production)
# S3_BUCKET=rmbl-knowledge-hub
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1
# S3_ENDPOINT=

# External API contact emails (for polite API usage)
# CROSSREF_MAILTO=knowledgehub@rmbl.org
# UNPAYWALL_EMAIL=knowledgehub@rmbl.org

# Voyage AI (for embeddings / concept graph / semantic search)
# Get a key at https://dash.voyageai.com/
# VOYAGE_API_KEY=
